# ============================
# FixNow — Variáveis de Ambiente
# ============================
# Copie este arquivo para .env e preencha com seus valores
# NUNCA commite o arquivo .env no Git

# --- Aplicação ---
APP_NAME=FixNow
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=sua-chave-secreta-aqui-troque-em-producao

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# --- Banco de Dados (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://fixnow:fixnow123@localhost:5432/fixnow_db
DATABASE_TEST_URL=postgresql+asyncpg://fixnow:fixnow123@localhost:5432/fixnow_test_db

# --- Cache (Redis) ---
REDIS_URL=redis://localhost:6379/0

# --- JWT ---
JWT_SECRET_KEY=jwt-chave-secreta-aqui
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Kafka (Streaming) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_SERVICES=fixnow.services
KAFKA_TOPIC_TRACKING=fixnow.tracking
KAFKA_TOPIC_NOTIFICATIONS=fixnow.notifications

# --- Matching ---
MATCHING_WEIGHT_PROXIMITY=0.30
MATCHING_WEIGHT_RATING=0.25
MATCHING_WEIGHT_TRUST_SCORE=0.20
MATCHING_WEIGHT_AVAILABILITY=0.15
MATCHING_WEIGHT_RESPONSE_TIME=0.10
MATCHING_MAX_DISTANCE_KM=30

# --- Pagamentos ---
PAYMENT_GATEWAY_URL=https://api.pagamento.com
PAYMENT_GATEWAY_KEY=sua-chave-pagamento

# --- Logs ---
LOG_LEVEL=INFO
